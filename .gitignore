# Python
.venv/
__pycache__/
*.pyc
.env

# Terraform — state, provider cache, and env-specific vars (contain secrets)
src/infra/terraform/.terraform/
src/infra/terraform/terraform.tfstate
src/infra/terraform/terraform.tfstate.backup
src/infra/terraform/.terraform.lock.hcl
**/*.tfvars

# Runtime-generated local data — not committed.
# data/analytics/ : traces.jsonl, feedback.jsonl (raw append logs) + analytics.db (SQLite)
# data/data_quality/ : data_quality.db (SQLite, populated by POST /data-quality/refresh)
# src/mlflow.db and src/mlruns/ are committed (eval runs generated offline, MLflow UI works after clone).
# Ignore a stale mlflow.db at root in case the old path lingers after the move to src/.
mlflow.db
data/
# Legacy paths — no longer written by the app but gitignored as a safety net.
data_quality.db
traces/

# Node (belt-and-suspenders — src/frontend/.gitignore also covers these)
node_modules/
dist/

# OS
.DS_Store
Thumbs.db
output.txt